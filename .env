PORT=3000

# WhatsApp — get from Meta Developer Dashboard
WA_PHONE_NUMBER_ID=     # Your phone number's ID (not the number itself)
WA_ACCESS_TOKEN=        # Permanent system user token (not temporary)
WA_BUSINESS_ACCOUNT_ID= # Your WABA ID
WA_VERIFY_TOKEN=        # Any random secret string you choose, e.g. "myapp_secret_123"
WA_API_VERSION=v19.0

# Instagram — same Meta app
IG_USER_ID=             # Instagram Business Account ID
IG_ACCESS_TOKEN=        # Page access token (long-lived, 60 days)
IG_APP_ID=              # Your Facebook App ID
IG_APP_SECRET=          # Your Facebook App Secret
IG_VERIFY_TOKEN=        # Another random string you choose

NODE_ENV=production
LOG_LEVEL=info